# driftlock .env.example
# -------------------------------------------------------
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it contains real license keys.
# -------------------------------------------------------

# Developer Mode / Integration Testing
# Set to '1' to bypass Gumroad license check when running tests locally.
# Leave blank (or '0') for production / any real usage.
DRIFTLOCK_SKIP_LICENSE_CHECK=

# Test license keys for the integration tests that hit the real Gumroad API.
# Replace with actual keys from your Gumroad account.
DRIFTLOCK_TEST_KEY_PRO=your-pro-license-key-here
DRIFTLOCK_TEST_KEY_TEAM=your-team-license-key-here
# Free: no key needed — test by simply not calling `driftlock login`